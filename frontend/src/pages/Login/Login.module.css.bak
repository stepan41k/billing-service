.root {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10px;
  background: #080a10;
  position: relative;
}

.card {
  position: relative;
  z-index: 1;
  width: 340px;
  background: #05060a;
  border: 1px solid #1a1d2e;
  border-radius: 10px;
  padding: 28px 24px 22px;
  box-shadow: 0 8px 40px rgba(0, 0, 0, 0.45);
}

.fields {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.title {
  font-size: 20px;
  font-weight: 600;
  color: #e8eaf6;
  margin: 0 0 4px;
  letter-spacing: -0.01em;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 5px;
  font-size: 12px;
  color: #5a5e72;
}

.field input {
  background: #080a10;
  border: 1px solid #1a1d2e;
  border-radius: 6px;
  padding: 8px 10px;
  color: #e8eaf6;
  font-size: 13px;
  outline: none;
  transition: border-color 0.15s;
}

.field input:focus {
  border-color: #5865f2;
}

.error {
  font-size: 12px;
  color: #ed4245;
  background: #1a0808;
  border: 1px solid #2a1010;
  border-radius: 6px;
  padding: 8px 10px;
  margin: 0;
}

.btn {
  width: 100%;
  padding: 10px;
  background: transparent;
  border: 1px solid #3d4480;
  color: #9096c8;
  border-radius: 6px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.15s, border-color 0.15s, color 0.15s;
}

.btn:hover:not(:disabled) {
  background: #0d0f1f;
  border-color: #5865f2;
  color: #c8cce8;
}

.btn:disabled {
  opacity: 0.35;
  cursor: not-allowed;
}

.switchWrap {
  position: relative;
  z-index: 1;
  width: 340px;
}

.switchBtn {
  width: 100%;
  padding: 10px;
  background: transparent;
  border: 1px solid #1a1d2e;
  border-radius: 6px;
  color: #5a5e72;
  font-size: 13px;
  cursor: pointer;
  transition: border-color 0.15s, color 0.15s;
  letter-spacing: 0.01em;
}

.switchBtn:hover {
  border-color: #2e3250;
  color: #c8cce8;
}
