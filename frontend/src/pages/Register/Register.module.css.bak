.root {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10px;
  background: #080a10;
  position: relative;
}

.card {
  position: relative;
  z-index: 1;
  width: 340px;
  background: #05060a;
  border: 1px solid #1a1d2e;
  border-radius: 10px;
  padding: 28px 24px 22px;
  box-shadow: 0 8px 40px rgba(0, 0, 0, 0.45);
}

.fields {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.title {
  font-size: 20px;
  font-weight: 600;
  color: #e8eaf6;
  margin: 0 0 4px;
  letter-spacing: -0.01em;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 5px;
  font-size: 12px;
  color: #5a5e72;
}

.field input {
  background: #080a10;
  border: 1px solid #1a1d2e;
  border-radius: 6px;
  padding: 8px 10px;
  color: #e8eaf6;
  font-size: 13px;
  outline: none;
  transition: border-color 0.15s;
}

.field input:focus {
  border-color: #5865f2;
}

.phoneWrap {
  display: flex;
  align-items: center;
  background: #080a10;
  border: 1px solid #1a1d2e;
  border-radius: 6px;
  overflow: hidden;
  transition: border-color 0.15s;
}

.phoneWrap:focus-within {
  border-color: #5865f2;
}

.phonePrefix {
  padding: 8px 8px 8px 10px;
  color: #5a5e72;
  font-size: 13px;
  user-select: none;
}

.phoneInput {
  flex: 1;
  background: transparent;
  border: none !important;
  padding: 8px 10px 8px 2px;
  color: #e8eaf6;
  font-size: 13px;
  outline: none;
}

.error {
  font-size: 12px;
  color: #ed4245;
  background: #1a0808;
  border: 1px solid #2a1010;
  border-radius: 6px;
  padding: 8px 10px;
  margin: 0;
}

.success {
  font-size: 12px;
  color: #3ba55c;
  background: #081308;
  border: 1px solid #0e2a1a;
  border-radius: 6px;
  padding: 8px 10px;
  margin: 0;
}

.btn {
  width: 100%;
  padding: 10px;
  background: #5865f2;
  color: #fff;
  border: none;
  border-radius: 6px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.15s;
}

.btn:hover:not(:disabled) {
  background: #4752c4;
}

.btn:disabled {
  opacity: 0.35;
  cursor: not-allowed;
}

.signature {
  text-align: center;
  font-family: 'DM Sans', 'SF Pro Display', system-ui, sans-serif;
  font-weight: 200;
  font-size: 13px;
  color: #2e3150;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  margin: 4px 0 0;
}

/* ── auth switch button (inside card) ── */
.switchLink {
  display: block;
  text-decoration: none;
}

.switchBtn {
  width: 100%;
  padding: 9px;
  background: transparent;
  border: 1px solid #1f2235;
  border-radius: 6px;
  color: #4a4e66;
  font-size: 12px;
  cursor: pointer;
  transition: border-color 0.15s, color 0.15s;
  letter-spacing: 0.01em;
}

.switchBtn:hover {
  border-color: #2e3250;
  color: #9096b8;
}
