# FireBird setting
FB_USER=SYSDBA
FB_PASSWORD=masterkey
FB_HOST="192.168.1.22"
FB_PORT="3050"
FB_NAME="C:/Data/maximadb.fdb"

# Billing setting
BILLING_ACCESS_SECRET=технолоджиAccess
BILLING_REFRESH_SECRET=технолоджиRefresh

# Frontend
VITE_USE_MOCKS=false
VITE_ENV=production




# Путь к файлу с конйигурацией
CONFIG_PATH="config/local.yaml"

# Сикреты access and refresh tokens
ACCESS_SECRET=технолоджиAccess
REFRESH_SECRET=технолоджиRefresh

# Конфигурация Firebird через .env
FB_HOST="localhost"
FB_PORT="3050"
FB_NAME="/Users/odner/databases/mxc_billing.db"
FB_USER="mxc_billing_user"
FB_PASSWORD="mxc_billing_sycret"

# Путь для миграций
MIGRATIONS_PATH="./migrations"


env: "dev"

http_server:
  host: "0.0.0.0"
  port: "8443"
  timeout: 10s
  idle_timeout: 60s

firebird:
  max_open_conns: 10
  conn_timeout: 5s
  charset: "UTF8"

token:
  access_token_ttl: 15m
  refresh_token_ttl: 43200m
